{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier src index.html vite.config.ts postcss.config.mjs tsconfig.json eslint.config.js package.json src/styles --check",
    "format:write": "prettier src index.html vite.config.ts postcss.config.mjs tsconfig.json eslint.config.js package.json src/styles --write"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/node": "^24.3.1",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.0",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
